.tip {
  margin: 4rpx 0 22rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  color: #c2410c;
  font-size: 26rpx;
}

.summary {
  margin-top: 14rpx;
  color: #374151;
}

.score {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.detail-card {
  margin-top: 20rpx;
}

.q-title {
  font-size: 30rpx;
  line-height: 1.6;
  font-weight: 500;
}

.line {
  margin-top: 10rpx;
  color: #4b5563;
}

.ok {
  color: #15803d;
}

.bad {
  color: #b91c1c;
}
